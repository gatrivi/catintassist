# Deepgram — required for live transcription
REACT_APP_DEEPGRAM_API_KEY=

# Azure Translator — same Vercel flow as Deepgram (Project → Settings → Environment Variables → redeploy)
REACT_APP_AZURE_TRANSLATOR_KEY=
REACT_APP_AZURE_TRANSLATOR_REGION=brazilsouth

# Firebase — Google login + cloud settings (optional; app works without)
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_APP_ID=