{
  "name": "catintassist",
  "version": "4.84.24",
  "private": true,
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "firebase": "^12.15.0",
    "idb-keyval": "^6.2.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-grid-layout": "^2.2.2",
    "react-scripts": "5.0.1",
    "slot-text": "^0.2.2",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "node scripts/build-with-local-temp.js",
    "test": "react-scripts test --watchAll=false",
    "test:watch": "react-scripts test",
    "test:transcription": "react-scripts test --watchAll=false --testPathPattern=\"(captionEngine|fixtureReplay|applyDeepgramTranscriptPayload|sensitiveDataProtector)\"",
    "test:fixtures": "react-scripts test --watchAll=false --testPathPattern=\"fixtureReplay\"",
    "test:translation": "react-scripts test --watchAll=false --testPathPattern=\"(translationApplicator|translationFixtureReplay|translationSensitiveTokens|translationQuality)\"",
    "test:phase0-smoke": "react-scripts test --watchAll=false --testPathPattern=\"phase0SmokeChecklist\"",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
